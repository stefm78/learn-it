    logic:
      trigger: null
      condition: null
      effect: Pointage fédérateur vers le Core Constitution.
      scope: link_reference
  - id: LINK_REF_CORE_LEARNIT_REFERENTIEL_V1_0
    authority: reference
    core_type: LINK
    source_anchor: '[INTERCORE]'
    depends_on: []
    relations: []
    patchable: false
    parameterizable: false
    human_readable: Référence explicite vers le Core Référentiel Learn-it v1.0.
    logic:
      trigger: null
