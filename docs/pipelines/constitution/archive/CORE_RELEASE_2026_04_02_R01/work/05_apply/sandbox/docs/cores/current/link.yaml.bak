    - type: binds
      target:
        id: LINK_REF_CORE_LEARNIT_REFERENTIEL_V1_0::TYPE_REFERENTIEL_REFERENTIAL_PARAMETER_LAYER
    patchable: false
    parameterizable: false
    human_readable: 'Binding inter-Core des composantes MSC P/R/A vers leurs paramètres référentiels minimaux obligatoires.

      '
    logic:
      trigger: Lecture ou audit d'un calcul MSC
      condition: Une composante MSC constitutionnelle requiert un paramètre opératoire délégué.
      effect: 'La résolution de P, R et A vers les paramètres référentiels minimaux obligatoires devient explicite et auditables sans déplacer la logique MSC hors Constitution.

        '
      scope: intercore_binding
  - id: TYPE_BINDING_FEEDBACK_COVERAGE_TO_REFERENTIEL_THRESHOLD
