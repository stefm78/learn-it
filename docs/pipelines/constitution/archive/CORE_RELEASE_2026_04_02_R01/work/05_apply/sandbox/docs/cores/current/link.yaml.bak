        id: LINK_REF_CORE_LEARNIT_REFERENTIEL_V1_0::EVENT_REFERENTIEL_FEEDBACK_COVERAGE_LOW
    patchable: false
    parameterizable: false
    human_readable: 'Binding inter-Core entre la matrice constitutionnelle de couverture feedback, son fallback générique, le seuil référentiel de couverture et l''événement de sous-couverture.

      '
    logic:
      trigger: Audit de couverture feedback ou fallback d'erreur non couverte
      condition: Une matrice de couverture existe et un seuil référentiel est applicable.
      effect: 'Le fallback constitutionnel et le signal référentiel de couverture basse sont fédérés sans introduire de logique métier autonome dans le LINK.

        '
      scope: intercore_binding
  - id: TYPE_BINDING_PATCH_TRIGGER_GOVERNANCE_CHAIN
    authority: derived
    core_type: LINK
    source_anchor: '[S6][S14][S16][tables][PATCH_STAGE03]'
    depends_on:
    - LINK_REF_CORE_LEARNIT_CONSTITUTION_V1_9
    - LINK_REF_CORE_LEARNIT_REFERENTIEL_V1_0
    - TYPE_BINDING_REFERENTIEL_TO_CONSTITUTION_GOVERNING_INVARIANTS
