    - type: binds
      target:
        id: LINK_REF_CORE_LEARNIT_REFERENTIEL_V1_0::INV_REFERENTIEL_VC_UNKNOWN_MEANS_NO_INFERENCE
    patchable: false
    parameterizable: false
    human_readable: 'Binding inter-Core de la chaîne d''autorité des signaux état apprenant, reliant les axes constitutionnels et auto-rapports aux règles référentielles de précédence, reweighting et non-inférence.

      '
    logic:
      trigger: Résolution d'un état apprenant multi-sources
      condition: Les Core Constitution et Référentiel sont fédérés dans le même système.
      effect: 'La Constitution déclare les axes, sources autorisées et statuts admissibles ; le Référentiel borne l''ordre de résolution, le reweighting et les interdits d''inférence.

        '
      scope: intercore_binding
  - id: TYPE_BINDING_MSC_COMPONENTS_TO_REFERENTIEL_PARAMETERS
    authority: derived
    core_type: LINK
    source_anchor: '[S1][S2][S20][PATCH_STAGE03]'
