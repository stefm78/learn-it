      scope: link_reference
  - id: TYPE_BINDING_CONSTITUTION_TO_REFERENTIEL_OPERATIONAL_PARAMETERS
    authority: derived
    core_type: LINK
    source_anchor: '[S1][S14][S20]'
    depends_on:
    - LINK_REF_CORE_LEARNIT_CONSTITUTION_V1_9
    - LINK_REF_CORE_LEARNIT_REFERENTIEL_V1_0
    relations:
