    patchable: false
    parameterizable: true
    human_readable: Knowledge Unit atomique du graphe, à typage épistémologique obligatoire.
    logic:
      trigger: null
      condition: Toute KU doit être typée.
      effect: Le type KU conditionne feedback, trajectoire, proxys et lecture du MSC.
      scope: knowledge_model
  - id: TYPE_KNOWLEDGE_GRAPH
    authority: primary
    core_type: CONSTITUTION
    source_anchor: '[S4][S18]'
    depends_on:
