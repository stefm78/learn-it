    core_type: CONSTITUTION
    source_anchor: '[S8][S20]'
    depends_on:
    - REF_CORE_LEARNIT_REFERENTIEL_V0_6_IN_CONSTITUTION
    relations: []
    patchable: false
    parameterizable: true
    human_readable: Composante A d’autonomie.
    logic:
      trigger: null
      condition: Transitions sans aide observées.
      effect: Contribution à la maîtrise de base.
      scope: runtime_evaluation
  - id: TYPE_MASTERY_COMPONENT_T
    authority: primary
    core_type: CONSTITUTION
    source_anchor: '[S17b][S20]'
