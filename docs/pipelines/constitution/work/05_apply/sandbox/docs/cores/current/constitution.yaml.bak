    patchable: false
    parameterizable: false
    human_readable: 'Niveaux d’autonomie moteur : autonome, hybride recommandé, hybride bloquant, assisté.'
    logic:
      trigger: Conception du déploiement
      condition: Cadre d’accompagnement déclaré.
      effect: Régime d’autonomie applicable.
      scope: deployment
  INVARIANTS:
  - id: INV_MSC_AND_STRICT
    authority: primary
    core_type: CONSTITUTION
    source_anchor: '[S17b]'
    depends_on:
    - TYPE_MASTERY_COMPONENT_P
    - TYPE_MASTERY_COMPONENT_R
    - TYPE_MASTERY_COMPONENT_A
    relations:
    - type: governs
      target:
        id: TYPE_MASTERY_MODEL
    patchable: false
    parameterizable: false
    human_readable: Agrégation MSC par AND strict sur P, R et A.
    logic:
      trigger: Déclaration de maîtrise de base
      condition: P, R et A satisfaits simultanément.
      effect: Maîtrise de base déclarée.
      scope: runtime_evaluation
  - id: INV_TRANSFER_SEPARATE_FROM_BASE_MASTERY
    authority: primary
    core_type: CONSTITUTION
    source_anchor: '[S17b]'
    depends_on:
    - TYPE_MASTERY_COMPONENT_T
    relations:
    - type: constrains
      target:
        id: TYPE_MASTERY_MODEL
    patchable: false
    parameterizable: false
    human_readable: T est séparé de la maîtrise de base.
    logic:
      trigger: Déclaration de transférabilité
      condition: Maîtrise de base déjà établie.
      effect: T qualifie un niveau supérieur et n’est jamais un prérequis de base.
      scope: runtime_evaluation
  - id: INV_RUNTIME_FULLY_LOCAL
    authority: primary
    core_type: CONSTITUTION
    source_anchor: '[S4][S13]'
    depends_on:
    - TYPE_AUTONOMY_REGIME
    relations:
    - type: constrains
      target:
        id: TYPE_AUTONOMY_REGIME
    patchable: false
    parameterizable: false
    human_readable: Le moteur en usage est 100% local.
    logic:
      trigger: Exécution runtime
      condition: Usage apprenant actif.
      effect: Aucun appel réseau temps réel n’est autorisé.
      scope: runtime_architecture
  - id: INV_NO_RUNTIME_CONTENT_GENERATION
    authority: primary
    core_type: CONSTITUTION
    source_anchor: '[S13]'
    depends_on: []
    relations:
    - type: constrains
      target:
        id: TYPE_FEEDBACK_COVERAGE_MATRIX
    patchable: false
    parameterizable: false
    human_readable: Aucune génération de contenu en usage.
    logic:
      trigger: Sélection de contenu runtime
      condition: Besoin pédagogique détecté.
      effect: Le moteur sélectionne uniquement des artefacts préexistants.
      scope: runtime_architecture
  - id: INV_NO_TEXT_ONLY_FOR_PROCEDURAL_OR_PERCEPTUAL
    authority: primary
    core_type: CONSTITUTION
    source_anchor: '[S12]'
    depends_on:
    - TYPE_KNOWLEDGE_UNIT
    relations: []
    patchable: false
    parameterizable: false
    human_readable: Le canal textuel seul est interdit pour les KU procédurales et perceptuelles.
    logic:
      trigger: Conception des livrables
      condition: KU procédurale ou perceptuelle détectée.
      effect: Livrables multimodaux obligatoires.
      scope: design
  - id: INV_NO_PARTIAL_PATCH_STATE
    authority: primary
    core_type: CONSTITUTION
    source_anchor: '[S14]'
    depends_on:
    - TYPE_PATCH_ARTIFACT
    relations:
    - type: blocks
      target:
        id: EVENT_PATCH_INVALID
    patchable: false
    parameterizable: false
    human_readable: Un patch partiellement appliqué constitue un état interdit.
    logic:
      trigger: Application d’un patch
      condition: Atomicité non garantie ou échec intermédiaire.
      effect: Patch annulé ou rollback obligatoire.
      scope: patch_layer
  - id: INV_INVALID_PATCH_REJECTED
    authority: primary
    core_type: CONSTITUTION
    source_anchor: '[S14][S20]'
    depends_on:
    - TYPE_PATCH_IMPACT_SCOPE
    - REF_CORE_LEARNIT_REFERENTIEL_V0_6_IN_CONSTITUTION
    relations: []
    patchable: false
    parameterizable: false
    human_readable: Tout patch hors bornes ou sans impact_scope calculable est rejeté intégralement.
    logic:
      trigger: Validation locale de patch
      condition: Paramètre hors fourchette ou impact_scope indéterminé.
      effect: Rejet total.
      scope: patch_validation
  - id: INV_GRAPH_PROPAGATION_ONE_HOP
    authority: primary
    core_type: CONSTITUTION
    source_anchor: '[S17c]'
    depends_on:
    - TYPE_KNOWLEDGE_GRAPH
    relations: []
    patchable: false
    parameterizable: false
    human_readable: La propagation graphe est limitée à un saut.
    logic:
      trigger: Rétrogradation MSC
      condition: KU dépendantes explicites présentes.
      effect: Marquage prioritaire des dépendantes directes uniquement.
      scope: runtime_graph
  - id: INV_CONSERVATIVE_RULE_WITHOUT_AR_N1
    authority: primary
    core_type: CONSTITUTION
    source_anchor: '[S7]'
    depends_on:
    - TYPE_SELF_REPORT_AR_N1
    relations:
    - type: constrains
      target:
        id: TYPE_STATE_AXIS_ACTIVATION
    patchable: false
    parameterizable: false
    human_readable: En absence d’AR-N1, la réponse est conservatrice.
    logic:
      trigger: Signal runtime sans AR-N1
      condition: AR-N1 absent.
      effect: Scaffolding léger réversible sans dégradation punitive.
      scope: runtime_state
  - id: INV_VC_NOT_GENERAL_MOTIVATION_PROXY
    authority: primary
    core_type: CONSTITUTION
    source_anchor: '[S17d]'
    depends_on:
    - TYPE_STATE_AXIS_VALUE_COST
    relations: []
    patchable: false
    parameterizable: false
    human_readable: VC n’est ni un proxy général de motivation ni un levier de pénalité.
    logic:
      trigger: Interprétation de VC
      condition: VC basse ou inconnue.
      effect: Réponse distincte de la détresse ; aucune pénalisation.
      scope: runtime_state
  - id: INV_AUTHENTIC_CONTEXT_REQUIRED_FOR_BLOOM4
    authority: primary
    core_type: CONSTITUTION
    source_anchor: '[S17e]'
    depends_on:
    - TYPE_AUTHENTIC_CONTEXT
    relations:
    - type: blocks
      target:
        id: EVENT_HIGH_BLOOM_WITHOUT_AUTHENTIC_CONTEXT
    patchable: false
    parameterizable: false
    human_readable: Le contexte authentique est obligatoire pour Bloom ≥ 4.
    logic:
      trigger: Conception ou lancement d’une mission Bloom ≥ 4
      condition: Contexte authentique absent.
      effect: Mission interdite et plafonnement à Bloom 2.
      scope: analysis_design
  - id: INV_CONSTITUTION_REFERENTIAL_SEPARATION
    authority: primary
    core_type: CONSTITUTION
    source_anchor: '[S1]'
    depends_on:
    - REF_CORE_LEARNIT_REFERENTIEL_V0_6_IN_CONSTITUTION
    relations:
    - type: governs
      target:
        id: REF_CORE_LEARNIT_REFERENTIEL_V0_6_IN_CONSTITUTION
    patchable: false
    parameterizable: false
    human_readable: Séparation inviolable Constitution/Référentiel.
    logic:
      trigger: Gouvernance du système
      condition: Révision ou patch demandé.
      effect: La Constitution fixe le quoi/pourquoi ; le Référentiel borne le combien/comment.
      scope: governance
  - id: INV_KU_TYPING_REQUIRED
    authority: primary
    core_type: CONSTITUTION
    source_anchor: '[S16]'
    depends_on:
    - TYPE_KNOWLEDGE_UNIT
    relations: []
    patchable: false
    parameterizable: false
    human_readable: Toute KU doit être typée.
    logic:
      trigger: Construction de graphe ou design
      condition: KU non typée.
      effect: Le système est incomplet et doit être corrigé avant usage fiable.
      scope: analysis_design
  - id: INV_ASSISTED_MODE_REQUIRES_TUTORING
    authority: primary
    core_type: CONSTITUTION
    source_anchor: '[S17]'
    depends_on:
    - TYPE_AUTONOMY_REGIME
    relations: []
    patchable: false
    parameterizable: false
    human_readable: Le mode Assisté exige une infrastructure tutorale.
    logic:
      trigger: Choix du mode Assisté
      condition: Infrastructure de suivi tutoral absente.
      effect: Déploiement Assisté interdit.
      scope: deployment
  - id: INV_EXPLICIT_DEPENDENCY_EDGES_REQUIRED
    authority: primary
    core_type: CONSTITUTION
    source_anchor: '[S17c][S18]'
    depends_on:
    - TYPE_KNOWLEDGE_GRAPH
    relations: []
    patchable: false
    parameterizable: false
    human_readable: Les arêtes de dépendance doivent être explicites pour autoriser la propagation.
    logic:
      trigger: Analyse ou propagation d’incertitude
      condition: Arêtes non explicites.
      effect: Aucune propagation autorisée.
      scope: analysis_runtime_graph
  - id: INV_KNOWLEDGE_GRAPH_MUST_BE_ACYCLIC
    authority: primary
    core_type: CONSTITUTION
    source_anchor: '[S4][S18][PATCH_V1_8]'
    depends_on:
    - TYPE_KNOWLEDGE_GRAPH
    - TYPE_KNOWLEDGE_UNIT
    relations:
    - type: constrains
      target:
        id: TYPE_KNOWLEDGE_GRAPH
    patchable: false
    parameterizable: false
    human_readable: Le graphe des KU doit être acyclique.
    logic:
      trigger: Validation design ou chargement du graphe
      condition: Un cycle de dépendance est détecté.
      effect: État interdit ; déploiement bloqué ou chargement refusé.
      scope: knowledge_model
  - id: INV_SECONDARY_RETROGRADATION_IS_NEW_EVENT
    authority: primary
    core_type: CONSTITUTION
    source_anchor: '[S17c][PATCH_V1_8]'
    depends_on:
    - INV_GRAPH_PROPAGATION_ONE_HOP
    - TYPE_KNOWLEDGE_GRAPH
    relations:
    - type: constrains
      target:
        id: INV_GRAPH_PROPAGATION_ONE_HOP
    patchable: false
    parameterizable: false
    human_readable: Toute rétrogradation secondaire issue d’un échec diagnostique constitue un nouvel événement indépendant.
    logic:
      trigger: Échec à une tâche diagnostique de propagation
      condition: Une KU dépendante directe échoue à la vérification prioritaire.
      effect: Création d’un nouvel événement autonome de rétrogradation, soumis à la même limite de propagation à un saut ; aucune extension implicite de la propagation courante.
      scope: runtime_graph
  - id: INV_PATCH_LOCAL_VALIDATION_MUST_BE_DETERMINISTIC
    authority: primary
    core_type: CONSTITUTION
    source_anchor: '[S14][PATCH_V1_8]'
    depends_on:
    - TYPE_PATCH_ARTIFACT
    - TYPE_PATCH_IMPACT_SCOPE
    - TYPE_PATCH_QUALITY_GATE
    relations:
    - type: constrains
      target:
        id: TYPE_PATCH_ARTIFACT
    patchable: false
    parameterizable: false
    human_readable: La validation locale d’un patch ne peut reposer que sur des critères déterministes.
    logic:
      trigger: Validation locale de patch
      condition: Un critère sémantique, pédagogique ou interprétatif est requis localement pour décider.
      effect: État interdit ; ce critère doit être déplacé dans la chaîne hors session de QA pédagogique.
      scope: patch_validation
  - id: INV_MISSING_KU_TYPE_FORCES_SAFE_FALLBACK
    authority: primary
    core_type: CONSTITUTION
    source_anchor: '[S12][S14][PATCH_V1_8]'
    depends_on:
    - TYPE_KNOWLEDGE_UNIT
    - INV_KU_TYPING_REQUIRED
    relations:
    - type: constrains
      target:
        id: TYPE_KNOWLEDGE_UNIT
    patchable: false
    parameterizable: false
    human_readable: Une KU sans type déclaré déclenche un mode de sécurité et interdit toute adaptation fine.
    logic:
      trigger: Chargement ou sélection runtime d’une KU
      condition: Type KU absent, indéterminé ou invalide.
      effect: KU gelée pour l’adaptation fine ; feedback générique uniquement ; exclusion des règles dépendantes du type ; signal de correction obligatoire.
      scope: runtime_safety
  - id: INV_AR_N2_SHORT_FORM_REQUIRES_EXPLICIT_PRIORITY
    authority: primary
    core_type: CONSTITUTION
    source_anchor: '[S11][PATCH_V1_8]'
    depends_on:
    - TYPE_SELF_REPORT_AR_N2
    - TYPE_STATE_AXIS_VALUE_COST
    relations:
    - type: constrains
      target:
        id: TYPE_SELF_REPORT_AR_N2
    patchable: false
    parameterizable: false
    human_readable: Toute version courte d’AR-N2 doit expliciter la priorité entre mesure VC et intention de retour.
    logic:
      trigger: Conception d’un AR-N2 simplifié
      condition: Le nombre d’items ne permet pas de mesurer complètement VC et intention.
      effect: Une priorité déclarée et stable est obligatoire ; aucune inférence implicite d’un axe à partir de l’autre.
      scope: runtime_feedback
  - id: INV_PERSISTENT_DRIFT_REQUIRES_ESCALATION_IF_PATCH_BLOCKED
    authority: primary
    core_type: CONSTITUTION
    source_anchor: '[S14][PATCH_V1_8]'
    depends_on:
    - TYPE_PATCH_ARTIFACT
    - INV_INVALID_PATCH_REJECTED
    relations: []
    patchable: false
    parameterizable: false
    human_readable: Une dérive persistante non corrigeable par patch localement valide doit être escaladée.
    logic:
      trigger: Répétition d’un besoin de correction sur plusieurs cycles
      condition: Le signal de dérive persiste alors que le patch requis reste rejeté ou impossible.
      effect: Escalade obligatoire hors session vers la chaîne d’analyse/correction.
      scope: patch_governance
  - id: INV_PATCH_ARTIFACTS_MUST_BE_PRECOMPUTED_OFF_SESSION
    authority: primary
    core_type: CONSTITUTION
    source_anchor: '[S13][S14][PATCH_V1_8]'
    depends_on:
    - TYPE_PATCH_ARTIFACT
    - INV_RUNTIME_FULLY_LOCAL
    - INV_NO_RUNTIME_CONTENT_GENERATION
    relations:
    - type: constrains
      target:
        id: TYPE_PATCH_ARTIFACT
    patchable: false
    parameterizable: false
    human_readable: Les artefacts de patch doivent être générés, validés et empaquetés hors session avant leur application locale.
    logic:
      trigger: Préparation d’un patch
      condition: Le patch nécessite calcul, QA ou génération d’artefact.
      effect: Préparation exclusivement hors session ; aucune génération ou validation distante pendant l’usage apprenant.
      scope: patch_architecture
  - id: INV_CREATIVE_KU_AUTONOMY_REQUIRES_DETERMINISTIC_FEEDBACK_PATH
    authority: primary
    core_type: CONSTITUTION
    source_anchor: '[S12][S17][PATCH_V1_8]'
    depends_on:
    - TYPE_KNOWLEDGE_UNIT
    - TYPE_FEEDBACK_COVERAGE_MATRIX
    relations: []
    patchable: false
    parameterizable: false
    human_readable: Une KU créative ne peut être déployée en régime autonome que si son feedback local déterministe est explicitement formalisé.
    logic:
      trigger: Validation de déploiement d’une KU créative
      condition: Aucun chemin de feedback local déterministe n’est disponible.
      effect: Régime autonome interdit pour cette KU ; checkpoint humain ou redesign requis.
      scope: design_governance
  RULES:
  - id: RULE_NO_CALIBRATION_CONSERVATIVE_START
    authority: primary
    core_type: CONSTITUTION
    source_anchor: '[S2]'
    depends_on: []
    relations: []
    patchable: false
    parameterizable: false
    human_readable: En absence de calibrage, le système part d’une hypothèse conservatrice.
    logic:
      trigger: Initialisation sans calibrage
      condition: Calibrage absent.
      effect: Position initiale basse + déblocage manuel apprenant.
      scope: initialization
  - id: RULE_NON_EXAM_CONCEPT_KEPT_IN_GRAPH
    authority: primary
    core_type: CONSTITUTION
    source_anchor: '[S3]'
    depends_on:
    - TYPE_KNOWLEDGE_GRAPH
    relations: []
    patchable: false
    parameterizable: true
    human_readable: Un concept utile du corpus n’est pas supprimé du graphe même s’il est absent des annales.
    logic:
      trigger: Construction ou révision du graphe
      condition: Concept présent dans le corpus mais absent des annales.
      effect: Le concept est maintenu avec Bloom minimal et pondération réduite.
      scope: analysis_design
  - id: RULE_MISCONCEPTION_REQUIRES_COGNITIVE_CONFLICT
    authority: primary
    core_type: CONSTITUTION
    source_anchor: '[S3][S18]'
    depends_on:
    - TYPE_KNOWLEDGE_UNIT
    relations:
    - type: triggers
      target:
        id: ACTION_PLAN_COGNITIVE_CONFLICT_MISSION
    patchable: false
    parameterizable: false
    human_readable: Une misconception impose une mission de conflit cognitif.
    logic:
      trigger: KU flaggée misconception
      condition: Misconception détectée.
      effect: Mission de conflit cognitif obligatoire.
      scope: design_runtime
  - id: RULE_LONG_INTERRUPTION_REQUIRES_DIAGNOSTIC_RESUME
    authority: primary
    core_type: CONSTITUTION
    source_anchor: '[S5]'
    depends_on:
    - REF_CORE_LEARNIT_REFERENTIEL_V0_6_IN_CONSTITUTION
    relations:
    - type: triggers
      target:
        id: ACTION_PLAN_SHORT_DIAGNOSTIC_TASK
    patchable: false
    parameterizable: true
    human_readable: Une interruption longue impose une reprise diagnostique.
    logic:
      trigger: Reprise après interruption
      condition: Durée d’interruption > seuil_R.
      effect: Session diagnostique de reprise.
      scope: runtime_resume
  - id: RULE_AR_N1_OVERRIDES_PROXY
    authority: primary
    core_type: CONSTITUTION
    source_anchor: '[S11]'
    depends_on:
    - TYPE_SELF_REPORT_AR_N1
    relations:
    - type: validates
      target:
        id: TYPE_STATE_AXIS_ACTIVATION
    - type: triggers
      target:
        id: ACTION_LOG_AR_PROXY_DISCORDANCE
    patchable: false
    parameterizable: true
    human_readable: AR-N1 prime sur les proxys.
    logic:
      trigger: Discordance AR-N1 / proxy
      condition: AR-N1 disponible et contradictoire au proxy.
      effect: AR-N1 prévaut ; discordance journalisée.
      scope: runtime_state
  - id: RULE_UNCOVERED_ERROR_GENERIC_FEEDBACK
    authority: primary
    core_type: CONSTITUTION
    source_anchor: '[S4]'
    depends_on:
    - TYPE_FEEDBACK_COVERAGE_MATRIX
    relations:
    - type: triggers
      target:
        id: EVENT_UNCOVERED_ERROR
    patchable: false
    parameterizable: true
    human_readable: 'Erreur non couverte : feedback générique de processus et flag hors-taxonomie.'
    logic:
      trigger: Erreur sans template couvert
      condition: Aucune entrée matrice applicable.
      effect: Feedback générique + flag erreur-hors-taxonomie.
      scope: runtime_feedback
  - id: RULE_PERSISTENT_LOW_VC_TRIGGERS_RELEVANCE_PATCH
    authority: primary
    core_type: CONSTITUTION
    source_anchor: '[S17d]'
    depends_on:
    - TYPE_STATE_AXIS_VALUE_COST
    - REF_CORE_LEARNIT_REFERENTIEL_V0_6_IN_CONSTITUTION
    relations:
    - type: triggers
      target:
        id: ACTION_TRIGGER_RELEVANCE_PATCH
    patchable: false
    parameterizable: true
    human_readable: VC basse persistante déclenche un patch de relevance, pas une baisse de difficulté.
    logic:
      trigger: Persistance de VC basse
      condition: Seuil de persistance atteint.
      effect: Révision contextualisation/enjeux/contexte authentique ; difficulté inchangée.
      scope: patch_governance
  - id: RULE_AR_REFRACTORY_PROFILE_TRIGGERS_SOLLICITATION_PATCH
    authority: primary
    core_type: CONSTITUTION
    source_anchor: '[S7]'
    depends_on:
    - TYPE_SELF_REPORT_AR_N1
    - REF_CORE_LEARNIT_REFERENTIEL_V0_6_IN_CONSTITUTION
    relations:
    - type: triggers
      target:
        id: ACTION_TRIGGER_AR_SOLLICITATION_PATCH
    patchable: false
    parameterizable: true
    human_readable: Le profil AR-réfractaire déclenche une adaptation du mode de sollicitation.
    logic:
      trigger: Détection d’un profil AR-réfractaire
      condition: Fenêtre de non-réponse atteinte.
      effect: Patch de mode de sollicitation, sans pénalisation.
      scope: patch_governance
  - id: RULE_MSC_DOWNGRADE_MARKS_DEPENDENTS
    authority: primary
    core_type: CONSTITUTION
    source_anchor: '[S17c]'
    depends_on:
    - INV_GRAPH_PROPAGATION_ONE_HOP
    - INV_EXPLICIT_DEPENDENCY_EDGES_REQUIRED
    relations:
    - type: triggers
      target:
        id: ACTION_PLAN_SHORT_DIAGNOSTIC_TASK
    patchable: false
    parameterizable: true
    human_readable: Une rétrogradation MSC marque en priorité les dépendantes directes.
    logic:
      trigger: Rétrogradation MSC
      condition: Arêtes explicites disponibles.
      effect: Marquage des dépendantes directes + tâche diagnostique courte.
      scope: runtime_graph
  - id: RULE_GF08_UNCOVERED_CONFLICT_CONSERVATIVE_RESPONSE
    authority: primary
    core_type: CONSTITUTION
    source_anchor: '[S14][S20]'
    depends_on: []
    relations:
    - type: triggers
      target:
        id: ACTION_LOG_UNCOVERED_CONFLICT
    patchable: false
    parameterizable: false
    human_readable: Un conflit GF-08 non couvert reçoit une réponse conservatrice.
    logic:
      trigger: Conflit inter-principes non couvert
      condition: Aucune hiérarchie explicite ne tranche.
      effect: Réponse conservatrice + log pour futur patch.
      scope: runtime_governance
  - id: RULE_SESSION_INTENTION_NON_BLOCKING
    authority: primary
    core_type: CONSTITUTION
    source_anchor: '[S11]'
    depends_on:
    - TYPE_SELF_REPORT_AR_N2
    relations: []
    patchable: false
    parameterizable: true
    human_readable: L’intention de session est informative, non bloquante et non pénalisée.
    logic:
      trigger: Fin de session
      condition: Intention de session recueillie ou absente.
      effect: Support de forethought SRL, sans contrainte adaptative.
      scope: runtime_feedback
  - id: RULE_UNVERIFIED_GAMIFICATION_PROBATION
    authority: primary
    core_type: CONSTITUTION
    source_anchor: '[S10][S18]'
    depends_on: []
    relations: []
    patchable: false
    parameterizable: true
    human_readable: Une gamification non vérifiée place le système en mode probatoire.
    logic:
      trigger: Déploiement d’une gamification non validée
      condition: Test de non-nuisance absent.
      effect: Mode probatoire.
      scope: deployment
  - id: RULE_LOW_SIS_NEVER_AUTO_PENALIZES
    authority: primary
    core_type: CONSTITUTION
    source_anchor: '[S15][S20]'
    depends_on:
    - TYPE_SESSION_INTEGRITY_SCORE
    relations: []
    patchable: false
    parameterizable: true
    human_readable: Un SIS bas ne pénalise jamais automatiquement l’apprenant.
    logic:
      trigger: Détection SIS bas
      condition: SIS sous seuil.
      effect: Pondération ou mise en attente possible, sans pénalisation automatique.
      scope: runtime_integrity
  - id: RULE_LEARNER_STATE_AXIS_UNKNOWN_ALLOWED
    authority: primary
    core_type: CONSTITUTION
    source_anchor: '[S7][S11][PATCH_V1_8__STAGE03]'
    depends_on:
    - TYPE_LEARNER_STATE_MODEL
    - TYPE_STATE_AXIS_ACTIVATION
    - TYPE_STATE_AXIS_VALUE_COST
    - TYPE_SELF_REPORT_AR_N1
    - TYPE_SELF_REPORT_AR_N2
    relations:
    - type: constrains
      target:
        id: TYPE_LEARNER_STATE_MODEL
    patchable: false
    parameterizable: false
    human_readable: 'Un axe d''état apprenant peut rester unknown, absent ou non-observable plutôt qu''être forcé quand la source autorisée manque ou n''est pas exploitable.

      '
    logic:
      trigger: Mise à jour de l'état apprenant
      condition: Source autorisée absente, non renseignée ou non exploitable selon la gouvernance active.
      effect: 'L''axe concerné reste unknown/absent/non-observable ; aucune valeur n''est forcée par simple complétion implicite au niveau constitutionnel.

        '
      scope: runtime_state
  PARAMETERS:
  - id: PARAM_PROVISIONAL_MASTERY_VERIFICATION_WINDOW
    authority: primary
    core_type: CONSTITUTION
    source_anchor: '[S2][S20]'
    depends_on: []
    relations: []
    patchable: true
    parameterizable: true
    human_readable: Fenêtre constitutionnellement déclarée pour vérifier une maîtrise provisoire.
    logic:
