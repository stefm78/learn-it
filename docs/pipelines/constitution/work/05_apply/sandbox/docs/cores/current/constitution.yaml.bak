    logic:
      trigger: Parcours nécessitant validation humaine
      condition: Niveau d’autonomie et risques pédagogiques déclarés.
      effect: Blocage ou validation du parcours.
      scope: runtime_governance
  - id: TYPE_MASTERY_MODEL
