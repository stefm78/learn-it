    patchable: false
    parameterizable: true
    human_readable: Graphe orienté de KU et de dépendances explicites.
    logic:
      trigger: Analyse
      condition: KU et arêtes de dépendance explicitement déclarées.
      effect: Le domaine d’apprentissage est instancié localement.
      scope: analysis_design
  - id: TYPE_HUMAN_CHECKPOINT
