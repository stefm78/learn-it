        id: INV_MSC_AND_STRICT
    patchable: false
    parameterizable: true
    human_readable: Modèle MSC composé des axes P, R, A et T.
    logic:
      trigger: Évaluation de la maîtrise
      condition: Composantes calculées localement.
      effect: Déclaration de maîtrise de base et, séparément, de transférabilité.
      scope: runtime_evaluation
  - id: TYPE_MASTERY_COMPONENT_P
    authority: primary
    core_type: CONSTITUTION
    source_anchor: '[S20]'
    depends_on:
    - REF_CORE_LEARNIT_REFERENTIEL_V0_6_IN_CONSTITUTION
    relations: []
    patchable: false
    parameterizable: true
    human_readable: Composante P de précision.
    logic:
      trigger: null
      condition: Seuils fournis par le Référentiel.
      effect: Contribution à la maîtrise de base.
      scope: runtime_evaluation
  - id: TYPE_MASTERY_COMPONENT_R
    authority: primary
    core_type: CONSTITUTION
    source_anchor: '[S5][S20]'
    depends_on:
    - REF_CORE_LEARNIT_REFERENTIEL_V0_6_IN_CONSTITUTION
    relations: []
    patchable: false
    parameterizable: true
    human_readable: Composante R de robustesse temporelle.
    logic:
      trigger: null
      condition: Seuils et multiplicateurs fournis ou bornés par le Référentiel.
      effect: Contribution à la maîtrise de base et à la reprise diagnostique.
      scope: runtime_evaluation
  - id: TYPE_MASTERY_COMPONENT_A
