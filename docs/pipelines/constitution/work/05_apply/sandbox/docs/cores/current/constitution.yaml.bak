    depends_on: []
    relations: []
    patchable: false
    parameterizable: false
    human_readable: Référence explicite vers le Core Référentiel Learn-it v0.6.
    logic:
      trigger: null
      condition: null
      effect: Référence externe explicite matérialisant une dépendance inter-Core.
      scope: intercore_reference
  - id: SYSTEM_LEARNIT
    authority: primary
    core_type: CONSTITUTION
    source_anchor: '[S1]'
    depends_on: []
    relations: []
