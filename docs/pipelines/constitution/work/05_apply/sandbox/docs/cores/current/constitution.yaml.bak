    patchable: false
    parameterizable: true
    human_readable: Axe optionnel Valeur-Coût perçue.
    logic:
      trigger: Clôture de session
      condition: Item VC de AR-N2 renseigné.
      effect: État VC mis à jour ; sinon axe inconnu.
