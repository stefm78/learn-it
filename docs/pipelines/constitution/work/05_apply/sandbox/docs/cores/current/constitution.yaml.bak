      scope: runtime_feedback
  - id: PARAM_AR_N2_INTERACTION_BUDGET
    authority: primary
    core_type: CONSTITUTION
    source_anchor: '[S20]'
    depends_on: []
    relations:
    - type: constrains
      target:
        id: TYPE_SELF_REPORT_AR_N2
    patchable: false
    parameterizable: true
    human_readable: Budget d’interaction AR-N2.
    logic:
      trigger: Affichage AR-N2
      condition: Fin de session.
      effect: Questionnaire visuel très court.
      scope: runtime_feedback
  - id: PARAM_AR_N3_INTERACTION_BUDGET
    authority: primary
    core_type: CONSTITUTION
    source_anchor: '[S20]'
    depends_on: []
    relations:
    - type: constrains
      target:
        id: TYPE_SELF_REPORT_AR_N3
    patchable: false
    parameterizable: true
    human_readable: Budget d’interaction AR-N3.
    logic:
      trigger: Affichage AR-N3
      condition: Bilan périodique.
      effect: Fenêtre d’items bornée.
      scope: runtime_feedback
  CONSTRAINTS:
  - id: CONSTRAINT_NO_AUTONOMOUS_PSYCHOLOGICAL_INFERENCE
    authority: primary
    core_type: CONSTITUTION
    source_anchor: '[S14]'
    depends_on:
    - TYPE_PATCH_ARTIFACT
    relations:
    - type: constrains
      target:
        id: TYPE_PATCH_QUALITY_GATE
    patchable: false
    parameterizable: false
    human_readable: Aucune inférence psychologique autonome non probatoire.
    logic:
      trigger: Conception d’un patch ou d’un mécanisme
      condition: Inférence psychologique autonome envisagée.
      effect: Interdiction.
      scope: patch_governance
  - id: CONSTRAINT_NO_ADAPTIVE_PHILOSOPHY_CHANGE
    authority: primary
    core_type: CONSTITUTION
    source_anchor: '[S14]'
    depends_on:
    - TYPE_PATCH_ARTIFACT
    relations:
    - type: constrains
      target:
        id: TYPE_PATCH_IMPACT_SCOPE
    patchable: false
    parameterizable: false
    human_readable: La philosophie adaptative ne peut pas être modifiée par patch.
    logic:
      trigger: Révision de patch
      condition: Modification de philosophie adaptative demandée.
      effect: Interdiction.
      scope: patch_governance
  - id: CONSTRAINT_NO_CHANGE_TO_AND_LOGIC
    authority: primary
    core_type: CONSTITUTION
    source_anchor: '[S14][S17b]'
    depends_on:
    - INV_MSC_AND_STRICT
    relations: []
    patchable: false
    parameterizable: false
    human_readable: La logique AND du MSC n’est pas patchable.
    logic:
      trigger: Révision de MSC
      condition: Modification de logique d’agrégation demandée.
      effect: Interdiction.
      scope: governance
  - id: CONSTRAINT_NO_CHANGE_TO_GRAPH_PROPAGATION_RULE
    authority: primary
    core_type: CONSTITUTION
    source_anchor: '[S14][S17c]'
    depends_on:
    - INV_GRAPH_PROPAGATION_ONE_HOP
    relations: []
    patchable: false
    parameterizable: false
    human_readable: La règle de propagation graphe n’est pas patchable.
    logic:
      trigger: Révision de propagation graphe
      condition: Modification de profondeur ou de logique demandée.
      effect: Interdiction.
      scope: governance
  - id: CONSTRAINT_NO_RUNTIME_FEEDBACK_GENERATION
    authority: primary
    core_type: CONSTITUTION
    source_anchor: '[S4][S13]'
    depends_on:
    - INV_NO_RUNTIME_CONTENT_GENERATION
    relations: []
    patchable: false
    parameterizable: false
    human_readable: Pas de génération de feedback à la volée.
    logic:
      trigger: Production d’un feedback runtime
      condition: Aucun template préindexé disponible.
      effect: Interdiction de génération ; appliquer feedback générique autorisé seulement.
      scope: runtime_feedback
  - id: CONSTRAINT_NO_HIGH_BLOOM_WITHOUT_AUTHENTIC_CONTEXT
    authority: primary
    core_type: CONSTITUTION
    source_anchor: '[S17e]'
    depends_on:
    - INV_AUTHENTIC_CONTEXT_REQUIRED_FOR_BLOOM4
    relations: []
    patchable: false
    parameterizable: false
    human_readable: Pas de Bloom ≥ 4 sans contexte authentique.
    logic:
      trigger: Conception ou exécution d’une mission haute Bloom
      condition: Contexte authentique absent.
      effect: Interdiction.
      scope: analysis_design
  - id: CONSTRAINT_NO_BIOMETRICS_OR_OFFSESSION_SURVEILLANCE
    authority: primary
    core_type: CONSTITUTION
    source_anchor: '[S15]'
    depends_on:
    - TYPE_INTEGRITY_MODES
    relations:
    - type: constrains
      target:
        id: TYPE_SESSION_INTEGRITY_SCORE
    patchable: false
    parameterizable: false
    human_readable: Pas de biométrie ni de surveillance hors session.
    logic:
      trigger: Extension de capture de données
      condition: Biométrie ou surveillance hors session envisagée.
      effect: Interdiction.
      scope: runtime_integrity
  - id: CONSTRAINT_NO_ASSISTED_DEPLOYMENT_WITHOUT_TUTORING
    authority: primary
    core_type: CONSTITUTION
    source_anchor: '[S17]'
    depends_on:
    - INV_ASSISTED_MODE_REQUIRES_TUTORING
    relations: []
    patchable: false
    parameterizable: false
    human_readable: Pas de déploiement Assisté sans tutorat.
    logic:
      trigger: Déploiement Assisté
      condition: Infrastructure tutorale absente.
      effect: Interdiction.
      scope: deployment
  EVENTS:
  - id: EVENT_MSC_DOWNGRADE
    authority: primary
    core_type: CONSTITUTION
    source_anchor: '[S17b][S17c]'
    depends_on:
    - TYPE_MASTERY_MODEL
    relations:
    - type: triggers
      target:
        id: RULE_MSC_DOWNGRADE_MARKS_DEPENDENTS
    patchable: false
    parameterizable: true
    human_readable: Rétrogradation MSC.
    logic:
      trigger: Échec d’une composante P, R ou A
      condition: Maîtrise de base auparavant satisfaite.
      effect: Déclassement et examen des dépendantes directes.
      scope: runtime_evaluation
  - id: EVENT_UNCOVERED_ERROR
    authority: primary
    core_type: CONSTITUTION
    source_anchor: '[S4][S18]'
    depends_on:
    - TYPE_FEEDBACK_COVERAGE_MATRIX
    relations:
    - type: triggers
      target:
        id: RULE_UNCOVERED_ERROR_GENERIC_FEEDBACK
    patchable: false
    parameterizable: true
    human_readable: Erreur hors-taxonomie.
    logic:
      trigger: Réponse apprenant invalide
      condition: Aucun pattern d’erreur couvert.
      effect: Feedback générique + signal de patch.
      scope: runtime_feedback
  - id: EVENT_PERSISTENT_LOW_VC
    authority: primary
    core_type: CONSTITUTION
    source_anchor: '[S7][S17d]'
    depends_on:
    - TYPE_STATE_AXIS_VALUE_COST
    - REF_CORE_LEARNIT_REFERENTIEL_V0_6_IN_CONSTITUTION
    relations:
    - type: triggers
      target:
        id: RULE_PERSISTENT_LOW_VC_TRIGGERS_RELEVANCE_PATCH
    patchable: false
    parameterizable: true
    human_readable: VC basse persistante.
    logic:
      trigger: Accumulation de sessions VC basse
      condition: Seuil référentiel atteint.
      effect: Déclencheur de patch relevance.
      scope: patch_governance
  - id: EVENT_AR_REFRACTORY_PROFILE_DETECTED
    authority: primary
    core_type: CONSTITUTION
    source_anchor: '[S7]'
    depends_on:
    - TYPE_SELF_REPORT_AR_N1
    - REF_CORE_LEARNIT_REFERENTIEL_V0_6_IN_CONSTITUTION
    relations:
    - type: triggers
      target:
        id: RULE_AR_REFRACTORY_PROFILE_TRIGGERS_SOLLICITATION_PATCH
    patchable: false
    parameterizable: true
    human_readable: Profil AR-réfractaire détecté.
    logic:
      trigger: Fenêtre de non-réponse AR-N1
